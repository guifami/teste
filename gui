public List<BspiDuplicateListReceipt> getPayload() {
    if (wrapperV3 != null) {
        return Optional.ofNullable(wrapperV3.getPayload())
                .orElseGet(Collections::emptyList)
                .stream()
                .map(BspiDuplicateListReceipt::new)
                .collect(Collectors.toList());
    }

    return Optional.ofNullable(wrapper)
            .map(ListPaymentReceiptResponseDTO::getPayload)
            .orElseGet(Collections::emptyList)
            .stream()
            .map(BspiDuplicateListReceipt::new)
            .collect(Collectors.toList());
}
