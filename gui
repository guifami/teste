let fusoHorario = time("03:00:00");

// Calcula automaticamente o último mês completo.
// Exemplo: em julho, consulta de 01/06 00:00 até 01/07 00:00.
let agoraLocal = now() - fusoHorario;
let inicioMesAtualUTC = startofmonth(agoraLocal) + fusoHorario;
let inicioMesAnteriorUTC = startofmonth(agoraLocal, -1) + fusoHorario;

// Localiza todos os containers do next-pix que existiram no período.
let containersNextPix =
    KubePodInventory
    | where TimeGenerated >= inicioMesAnteriorUTC
        and TimeGenerated < inicioMesAtualUTC
    | where Name contains "next-pix"
    | distinct ContainerID;

// Consulta os erros e calcula a volumetria.
ContainerLog
| where TimeGenerated >= inicioMesAnteriorUTC
    and TimeGenerated < inicioMesAtualUTC
| where ContainerID in (containersNextPix)
| where LogEntry has "ERROR"

// Remove as barras de escape do JSON: \"codigo\" vira "codigo".
| extend LogNormalizado = replace_regex(LogEntry, @'\\+"', '"')

// Extrai os campos presentes dentro da LogEntry.
| extend Codigo = extract(
        @'"codigo"\s*:\s*"([^"]+)"',
        1,
        LogNormalizado
    )
| extend Descricao = extract(
        @'"descricao"\s*:\s*"([^"]+)"',
        1,
        LogNormalizado
    )

// Desconsidera logs que não possuam o padrão esperado.
| where isnotempty(Codigo)

// Agrupa os erros.
| summarize Quantidade = count()
    by Codigo, Descricao

// Mostra primeiro os erros mais frequentes.
| order by Quantidade desc
