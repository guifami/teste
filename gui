    private void mockListReceiptPaginatedV4(
            Integer pageNumber,
            Integer pageSize,
            Integer qtdItems,
            boolean hasNextPage) {

        BspiMessageListReceiptResponse response =
                buildPaginatedResponseV3(
                        pageNumber,
                        pageSize,
                        qtdItems,
                        hasNextPage
                );

        when(bspiReceiptEngClient.listReceiptPaginated(any(), any()))
                .thenReturn(response);
    }

    private BspiMessageListReceiptResponse
            buildPaginatedResponseV3(
                    Integer pageNumber,
                    Integer pageSize,
                    Integer qtdItems,
                    boolean hasNextPage) {

        BspiMessageListReceiptResponse legacyResponse =
                BspiMessageListReceiptPaginateResponseBuilderV8
                        .start()
                        .withQtdItems(qtdItems)
                        .withPagination(
                                BspiPaginationBuilderV8
                                        .start()
                                        .withRecords(qtdItems)
                                        .withHasNextPage(hasNextPage)
                                        .withPageNumber(pageNumber)
                                        .withPageSize(pageSize)
                                        .build()
                        )
                        .build();

        return convertLegacyResponseToV3(legacyResponse);
    }

    private BspiMessageListReceiptResponse
            buildPaginatedResponseV3WithScheduleConfirmationCode(
                    String confirmationCode) {

        BspiMessageListReceiptResponse legacyResponse =
                BspiMessageListReceiptPaginateResponseBuilderV8
                        .start()
                        .withQtdItems(1)
                        .withPagination(
                                BspiPaginationBuilderV8
                                        .start()
                                        .withRecords(1)
                                        .withHasNextPage(false)
                                        .withPageNumber(1)
                                        .withPageSize(20)
                                        .build()
                        )
                        .build();

        List<ListPayload> payload =
                legacyResponse
                        .getWrapped()
                        .getPayload();

        payload.get(0)
                .setSet2eAgendamento(confirmationCode);

        return convertLegacyResponseToV3(legacyResponse);
    }

    private BspiMessageListReceiptResponse
            buildPaginatedResponseV3WithNullPayload() {

        BspiMessageListReceiptResponse legacyResponse =
                BspiMessageListReceiptPaginateResponseBuilderV8
                        .start()
                        .withPayload(null)
                        .build();

        ListPaymentReceiptResponseDTOV3 wrapperV3 =
                new ListPaymentReceiptResponseDTOV3();

        wrapperV3.setPayload(null);

        BspiMessageListReceiptResponse response =
                new BspiMessageListReceiptResponse(wrapperV3);

        response.setPagination(
                legacyResponse.getPagination()
        );

        return response;
    }

    private BspiMessageListReceiptResponse
            convertLegacyResponseToV3(
                    BspiMessageListReceiptResponse legacyResponse) {

        List<ListPayload> legacyPayload =
                legacyResponse.getWrapped() == null
                        || legacyResponse.getWrapped().getPayload() == null
                        ? Collections.emptyList()
                        : legacyResponse.getWrapped().getPayload();

        List<ListPayloadV3> payloadV3 =
                legacyPayload
                        .stream()
                        .map(this::convertPayloadToV3)
                        .collect(Collectors.toList());

        ListPaymentReceiptResponseDTOV3 wrapperV3 =
                new ListPaymentReceiptResponseDTOV3();

        if (legacyResponse.getWrapped() != null) {
            BeanUtils.copyProperties(
                    legacyResponse.getWrapped(),
                    wrapperV3,
                    "payload"
            );
        }

        wrapperV3.setPayload(payloadV3);

        BspiMessageListReceiptResponse response =
                new BspiMessageListReceiptResponse(wrapperV3);

        response.setPagination(
                legacyResponse.getPagination()
        );

        return response;
    }

    private ListPayloadV3 convertPayloadToV3(
            ListPayload source) {

        ListPayloadV3 target =
                new ListPayloadV3();

        BeanUtils.copyProperties(
                source,
                target
        );

        return target;
    }
