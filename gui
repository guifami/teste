package br.com.bradesco.next.pix.schedule.util;

public final class ConversionHelper {

    private ConversionHelper() {
        throw new IllegalStateException("Classe utilitária não pode ser instanciada");
    }

    public static Integer toIntegerOrNull(String value) {
        return toIntegerOrNull(value, "valor");
    }

    public static Integer toIntegerOrNull(String value, String fieldName) {
        if (value == null || value.isBlank()) {
            return null;
        }

        try {
            return Integer.valueOf(value.trim());
        } catch (NumberFormatException exception) {
            throw new IllegalArgumentException(
                    String.format(
                            "O campo '%s' deve possuir um valor numérico. Valor recebido: '%s'",
                            fieldName,
                            value
                    ),
                    exception
            );
        }
    }

    public static String toStringOrNull(Integer value) {
        return value == null ? null : value.toString();
    }
}
