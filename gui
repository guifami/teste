    @Test
    public void mustGenerateStaticQrCode() throws Exception {
        var request = mock(PixStaticQrCodeGenerationRequest.class);
        var cobeRequest = mock(CriarCobrancaRequest.class);
        var cobeResponse = mock(DadosCobrancaResponse.class);

        var responseConverterResult = new PixStaticQrCodeGenerationResponse();
        responseConverterResult.setEmv(EMV);
        responseConverterResult.setBase64(BASE64);

        mockCustomerName(CUSTOMER_NAME);
        mockShortUrl();

        when(cobeRequest.getIdentificacao()).thenReturn("IDENTIFICATION-123");
        when(cobeStaticQrCodeRequestConverter.convert(any(), anyString(), any()))
                .thenReturn(cobeRequest);
        when(canalApi.criarCobrancaEstaticaCanal(cobeRequest))
                .thenReturn(cobeResponse);
        when(cobeResponse.getEmv()).thenReturn(EMV);
        when(cobeResponse.getBase64()).thenReturn(BASE64);
        when(cobeStaticQrCodeResponseConverter.convert(cobeResponse))
                .thenReturn(responseConverterResult);

        var response = pixCoreService.generateStaticQrCode(
                CPF,
                CUSTOMER_ID,
                CUSTOMER_BRANCH,
                request
        );

        assertNotNull(response);
        assertEquals(response.getEmv(), EMV);
        assertEquals(response.getBase64(), BASE64);
        assertEquals(response.getIdentification(), "IDENTIFICATION-123");
        assertEquals(response.getEncryptedEmv(), SHORT_URL);
    }

