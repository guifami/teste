2. Adicione este método no PixRedundanceService
private PixScheduleResponse filterOnlyScheduledItems(
        PixScheduleResponse response) {

    if (response == null) {
        return null;
    }

    if (response.getSchedules() == null) {
        response.setSchedules(Collections.emptyList());
        return response;
    }

    List<PixScheduleDto> scheduledItems = response.getSchedules()
            .stream()
            .filter(Objects::nonNull)
            .filter(schedule -> Objects.nonNull(schedule.getStatus()))
            .filter(schedule ->
                    ScheduleSituationPixEnum.AGENDADO.equals(
                            schedule.getStatus()
                    )
            )
            .collect(Collectors.toList());

    response.setSchedules(scheduledItems);

    return response;
}
