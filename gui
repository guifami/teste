O método completo dessa parte fica:

public PixReceiptResponse getListReceiptsPaginatedV4(
        Long account,
        Integer branch,
        String cpf,
        Long customerId,
        String finalDate,
        String initialDate,
        String lastRegistryDate,
        Integer pageSize,
        boolean isMagic) {

    PixReceiptListV3Request request = new PixReceiptListV3Request();

    request.setFinalDate(toDate(finalDate));
    request.setInitialDate(toDate(initialDate));
    request.setPageSize(pageSize);
    request.setLastRegistryDate(
            lastRegistryDate == null || lastRegistryDate.trim().isEmpty()
                    ? null
                    : lastRegistryDate
    );

    PixReceiptResponse response = getListReceiptsPaginatedV4(
            account,
            branch,
            cpf,
            customerId,
            request
    );

    if (isMagic
            && response != null
            && response.getTransactions() != null) {

        response.getTransactions()
                .forEach(PixTransactionReceiptDto::convertDateToMagic);
    }

    return response;
}
