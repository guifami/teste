import static org.testng.Assert.assertNull;

@Test
void executeV3ListSchedulesPaginate_filterOnlyScheduledItemsTest() throws IOException {
    when(nextPixClient.getV3ListSchedulesPaginated(any(), any(), any(), any(), any(), any(), any(), any(), any())).thenReturn(mockSchedulesForFilter());
    V3ListSchedulesPaginatedDto dto = buildListScheduleDto(false);
    ResponseEntity<PixScheduleResponse> response = pixRedundanceService.executeV3ListSchedulesPaginate(dto);
    assertNotNull(response);
    assertEquals(response.getStatusCode(), HttpStatus.OK);
    assertNotNull(response.getBody());
    assertNotNull(response.getBody().getSchedules());
    assertEquals(response.getBody().getSchedules().size(), 1);
    assertEquals(response.getBody().getSchedules().get(0).getStatus(), ScheduleSituationPixEnum.AGENDADO);
}

