                .thenReturn(new PixTransactionsListV4Response());
    }

    @Test
    public void testGetListReceiptsPaginateV4WithScheduleConfirmationCode() {
        BspiMessageListReceiptResponse response =
                buildPaginatedResponseV3WithScheduleConfirmationCode(
                        "E60746948202106142359P3929000001"
                );

        when(bspiReceiptEngClient.listReceiptPaginated(any(), any()))
                .thenReturn(response);

        PixReceiptResponse listReceiptsPaginate =
                service.getListReceiptsPaginatedV4(
                        getMockPixReceiptListV3Request(),
                        getPixReceiptListDto()
                );

        assertNotNull(listReceiptsPaginate);
        assertNotNull(listReceiptsPaginate.getTransactions());
        assertEquals(listReceiptsPaginate.getTransactions().size(), 1);
        assertNotNull(listReceiptsPaginate.getPagination());
        assertEquals(
                listReceiptsPaginate
                        .getPagination()
                        .getNumberOfRecords()
                        .intValue(),
                1
        );

        PixTransactionReceiptDto transaction =
                listReceiptsPaginate.getTransactions().get(0);

        assertTrue(Boolean.TRUE.equals(transaction.getScheduled()));
        assertNotNull(transaction.getConfirmationCode());
    }

    @Test
    public void testGetListReceiptsPaginateV4WithScheduleConfirmationCodeException() {
        when(bspiReceiptEngClient.listReceiptPaginated(any(), any()))
