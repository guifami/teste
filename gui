private br.com.bradesco.next.client.next.pix.schedule.response.PixScheduleResponse filterOnlyScheduledItems(br.com.bradesco.next.client.next.pix.schedule.response.PixScheduleResponse response) {
    if (response == null || response.getSchedules() == null) {
        return response;
    }

    response.setSchedules(response.getSchedules().stream()
            .filter(Objects::nonNull)
            .filter(schedule -> Objects.nonNull(schedule.getStatus()))
            .filter(schedule -> br.com.bradesco.next.client.next.pix.schedule.enums.ScheduleSituationPixEnum.AGENDADO.equals(schedule.getStatus()))
            .collect(Collectors.toList()));

    return response;
}
