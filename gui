let fusoBrasil = 3h;
let agoraBrasil = now() - fusoBrasil;

// Último mês-calendário completo no horário do Brasil.
// Exemplo: se estivermos em julho, consulta de 01/06 até 01/07.
let inicioMesAnteriorUTC =
    startofmonth(agoraBrasil, -1) + fusoBrasil;

let inicioMesAtualUTC =
    startofmonth(agoraBrasil) + fusoBrasil;

ContainerLog
| where TimeGenerated >= inicioMesAnteriorUTC
    and TimeGenerated < inicioMesAtualUTC

// Nome do container/microsserviço.
| where Name contains "next-pix-payment"

// Filtra antes de executar as expressões regulares.
| where LogEntry has "ERROR"
| where LogEntry has "codigo"

| project LogEntry

// Funciona tanto para "codigo":"M0260"
// quanto para \"codigo\":\"M0260\".
| extend Codigo = extract(
    @'\\?"codigo\\?"\s*:\s*\\?"([^"\\]+)',
    1,
    LogEntry
)

// Extrai o campo descricao.
| extend Descricao = extract(
    @'\\?"descricao\\?"\s*:\s*\\?"([^"\\]+)',
    1,
    LogEntry
)

// Campo alternativo, caso o erro utilize descricaoDetalhe.
| extend DescricaoDetalhe = extract(
    @'\\?"descricaoDetalhe\\?"\s*:\s*\\?"([^"\\]+)',
    1,
    LogEntry
)

| where isnotempty(Codigo)

| extend DescricaoErro = coalesce(
    Descricao,
    DescricaoDetalhe,
    "SEM DESCRICAO"
)

| summarize Quantidade = count()
    by Codigo, Descricao = DescricaoErro

| order by Quantidade desc
