import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.*;

class ConversionHelperTest {

    @Test
    void shouldConvertStringToInteger() {
        Integer result = ConversionHelper.toIntegerOrNull("10");

        assertEquals(10, result);
    }

    @Test
    void shouldTrimAndConvertStringToInteger() {
        Integer result = ConversionHelper.toIntegerOrNull(" 10 ");

        assertEquals(10, result);
    }

    @Test
    void shouldReturnNullWhenValueIsNull() {
        assertNull(ConversionHelper.toIntegerOrNull(null));
    }

    @Test
    void shouldReturnNullWhenValueIsBlank() {
        assertNull(ConversionHelper.toIntegerOrNull("   "));
    }

    @Test
    void shouldThrowExceptionWhenValueIsNotNumeric() {
        IllegalArgumentException exception = assertThrows(
                IllegalArgumentException.class,
                () -> ConversionHelper.toIntegerOrNull(
                        "ABC",
                        "accountPlusDigit"
                )
        );

        assertTrue(exception.getMessage().contains("accountPlusDigit"));
        assertTrue(exception.getMessage().contains("ABC"));
    }

    @Test
    void shouldConvertIntegerToString() {
        assertEquals("10", ConversionHelper.toStringOrNull(10));
    }

    @Test
    void shouldReturnNullWhenIntegerIsNull() {
        assertNull(ConversionHelper.toStringOrNull(null));
    }
}
